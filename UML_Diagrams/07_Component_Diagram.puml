@startuml Gestion_Absences_Component_Diagram
title Diagramme des Composants

package "Client Layer" {
    component WebApp
    component MobileApp
    component SwaggerUI
}

package "API Layer" {
    component Gateway
    component JWTMid
    component ExceptionHandler
}

package "Controller Layer" {
    component AuthCtrl
    component UserCtrl
    component ClassCtrl
    component AbsenceCtrl
    component NotifCtrl
    component ReportCtrl
}

package "Service Layer" {
    component AuthSvc
    component UserSvc
    component ClassSvc
    component AbsenceSvc
    component NotifSvc
    component ReportSvc
}

package "Repository Layer" {
    component UserRepo
    component ClassRepo
    component AbsenceRepo
    component NotifRepo
}

package "Data Access Layer" {
    component DbCtx
    component EFCore
}

package "Database Layer" {
    component SQLServer
    component InMemDB
}

package "Cross-Cutting Concerns" {
    component Logger
    component Security
    component Validator
}

WebApp --> Gateway
MobileApp --> Gateway
SwaggerUI --> Gateway

Gateway --> JWTMid
JWTMid --> ExceptionHandler
ExceptionHandler --> AuthCtrl
ExceptionHandler --> UserCtrl
ExceptionHandler --> ClassCtrl
ExceptionHandler --> AbsenceCtrl
ExceptionHandler --> NotifCtrl
ExceptionHandler --> ReportCtrl

AuthCtrl --> AuthSvc
UserCtrl --> UserSvc
ClassCtrl --> ClassSvc
AbsenceCtrl --> AbsenceSvc
NotifCtrl --> NotifSvc
ReportCtrl --> ReportSvc

AuthSvc --> UserRepo
UserSvc --> UserRepo
ClassSvc --> ClassRepo
AbsenceSvc --> AbsenceRepo
AbsenceSvc --> NotifSvc
NotifSvc --> NotifRepo
ReportSvc --> AbsenceRepo

UserRepo --> DbCtx
ClassRepo --> DbCtx
AbsenceRepo --> DbCtx
NotifRepo --> DbCtx

DbCtx --> EFCore
EFCore --> SQLServer
EFCore --> InMemDB

AuthCtrl -.-> Logger
AbsenceCtrl -.-> Logger
AuthSvc -.-> Security
UserSvc -.-> Security
AbsenceSvc -.-> Validator

@enduml
