@startuml Gestion_Absences_Classes
!theme plain

package "Models" {
  class User {
    - id: int
    - firstName: string
    - lastName: string
    - email: string
    - passwordHash: string
    - role: string
    - isActive: boolean
    - createdAt: DateTime
    - updatedAt: DateTime
    --
    + Login(): void
    + ChangePassword(): void
    + ValidateEmail(): boolean
  }

  class Class {
    - id: int
    - name: string
    - description: string
    - teacherId: int
    - createdAt: DateTime
    --
    + AddStudent(): void
    + RemoveStudent(): void
    + GetStudents(): List
    + GetTeacher(): User
  }

  class Student {
    - id: int
    - userId: int
    - classId: int
    - enrolledAt: DateTime
    --
    + GetAbsences(): List
    + GetNotifications(): List
    + GetUser(): User
  }

  class Absence {
    - id: int
    - studentId: int
    - classId: int
    - absenceDate: DateTime
    - isJustified: boolean
    - reason: string
    - createdAt: DateTime
    --
    + Justify(): void
    + GetDetails(): AbsenceDto
    + GetStudent(): Student
  }

  class Notification {
    - id: int
    - userId: int
    - message: string
    - isRead: boolean
    - createdAt: DateTime
    --
    + MarkAsRead(): void
    + Delete(): void
    + GetUser(): User
  }

  class RefreshToken {
    - id: int
    - userId: int
    - token: string
    - expiresAt: DateTime
    - createdAt: DateTime
    --
    + IsExpired(): boolean
  }
}

package "DTOs" {
  class UserDto {
    - id: int
    - firstName: string
    - lastName: string
    - email: string
    - role: string
  }

  class LoginDto {
    - email: string
    - password: string
  }

  class RegisterDto {
    - firstName: string
    - lastName: string
    - email: string
    - password: string
    - role: string
  }

  class CreateAbsenceDto {
    - studentId: int
    - classId: int
    - absenceDate: DateTime
    - reason: string
  }

  class BulkAbsenceDto {
    - classId: int
    - absenceDate: DateTime
    - studentIds: List
    - reason: string
  }

  class AbsenceResponseDto {
    - id: int
    - studentName: string
    - className: string
    - absenceDate: DateTime
    - isJustified: boolean
  }

  class TokenDto {
    - accessToken: string
    - refreshToken: string
    - expiresIn: int
  }
}

package "Services" {
  interface IAuthService {
    + Login(LoginDto): TokenDto
    + Register(RegisterDto): UserDto
    + RefreshToken(string): TokenDto
    + ValidateToken(string): boolean
  }

  interface IUserService {
    + GetAllUsers(): List
    + GetUserById(int): UserDto
    + CreateUser(CreateUserDto): UserDto
    + UpdateUser(int, UpdateUserDto): UserDto
    + DeleteUser(int): void
  }

  interface IAbsenceService {
    + MarkAbsence(CreateAbsenceDto): AbsenceResponseDto
    + MarkBulkAbsences(BulkAbsenceDto): List
    + GetMyAbsences(int): List
    + GetClassAbsences(int): List
    + JustifyAbsence(int, string): AbsenceResponseDto
  }

  interface INotificationService {
    + SendNotification(int, string): Notification
    + GetNotifications(int): List
    + GetUnreadCount(int): int
    + MarkAsRead(int): void
  }

  interface IClassService {
    + GetAllClasses(): List
    + GetClassById(int): Class
    + CreateClass(CreateClassDto): Class
    + UpdateClass(int, UpdateClassDto): Class
    + DeleteClass(int): void
  }

  interface IReportService {
    + GetSummary(): ReportSummary
    + ExportCsv(): byte
    + ExportPdf(): byte
  }

  class AuthService implements IAuthService
  class UserService implements IUserService
  class AbsenceService implements IAbsenceService
  class NotificationService implements INotificationService
  class ClassService implements IClassService
  class ReportService implements IReportService
}

package "Repositories" {
  interface IRepository {
    + GetById(int): Object
    + GetAll(): List
    + Add(Object): void
    + Update(Object): void
    + Delete(int): void
  }

  interface IUserRepository extends IRepository {
    + GetByEmail(string): User
    + GetByRole(string): List
  }

  interface IAbsenceRepository extends IRepository {
    + GetByStudent(int): List
    + GetByClass(int): List
  }

  interface IClassRepository extends IRepository {
    + GetByTeacher(int): List
  }

  interface INotificationRepository extends IRepository {
    + GetByUser(int): List
    + GetUnread(int): List
  }

  class UserRepository implements IUserRepository
  class AbsenceRepository implements IAbsenceRepository
  class ClassRepository implements IClassRepository
  class NotificationRepository implements INotificationRepository
}

package "Controllers" {
  class AuthController {
    - authService: IAuthService
    --
    + Login(LoginDto): IActionResult
    + Register(RegisterDto): IActionResult
    + RefreshToken(string): IActionResult
  }

  class UserController {
    - userService: IUserService
    --
    + GetAll(): IActionResult
    + GetById(int): IActionResult
    + Create(CreateUserDto): IActionResult
    + Update(int, UpdateUserDto): IActionResult
    + Delete(int): IActionResult
  }

  class ClassController {
    - classService: IClassService
    --
    + GetAll(): IActionResult
    + GetById(int): IActionResult
    + Create(CreateClassDto): IActionResult
    + Update(int, UpdateClassDto): IActionResult
    + Delete(int): IActionResult
    + GetStudents(int): IActionResult
  }

  class AbsenceController {
    - absenceService: IAbsenceService
    --
    + MarkAbsence(CreateAbsenceDto): IActionResult
    + MarkBulk(BulkAbsenceDto): IActionResult
    + GetMyAbsences(): IActionResult
    + GetClassAbsences(int): IActionResult
  }

  class NotificationController {
    - notificationService: INotificationService
    --
    + GetNotifications(): IActionResult
    + GetUnread(): IActionResult
    + MarkAsRead(int): IActionResult
  }

  class ReportController {
    - reportService: IReportService
    --
    + GetSummary(): IActionResult
    + ExportCsv(): FileResult
    + ExportPdf(): FileResult
  }
}

User "1" -- "*" Class : enseigne
User "1" -- "*" Student : inscrit
Class "1" -- "*" Student : contient
Student "1" -- "*" Absence : a
Class "1" -- "*" Absence : concernant
User "1" -- "*" Notification : reçoit
User "1" -- "*" RefreshToken : possede

AuthController --> IAuthService
UserController --> IUserService
ClassController --> IClassService
AbsenceController --> IAbsenceService
NotificationController --> INotificationService
ReportController --> IReportService

AuthService --> IUserRepository
UserService --> IUserRepository
ClassService --> IClassRepository
AbsenceService --> IAbsenceRepository
AbsenceService --> INotificationService
NotificationService --> INotificationRepository

UserRepository --> User
AbsenceRepository --> Absence
ClassRepository --> Class
NotificationRepository --> Notification

@enduml
